{
  "name": "copy-code-path",
  "displayName": "Copy Code Path",
  "description": "Copy absolute file path and selected lines to clipboard",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copy-code-path.copyContext",
        "title": "Copy Code Path & Lines"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorHasSelection",
          "command": "copy-code-path.copyContext",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "copy-code-path.copyContext",
        "key": "cmd+shift+c",
        "mac": "cmd+shift+c",
        "when": "editorTextFocus && editorHasSelection"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3"
  }
}
